# Copy this file to `keystore.properties` (which is git-ignored) for LOCAL signed
# release builds. CI uses environment variables/secrets instead of this file.
#
# Never commit the real keystore.properties or the .p12 keystore.

storeFile=pawmino-release-key.p12
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=pawmino_key
keyPassword=YOUR_KEY_PASSWORD
